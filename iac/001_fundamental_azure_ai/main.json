{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "6150604810402841970"
    }
  },
  "parameters": {
    "resourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "리소스 그룹 이름"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "koreacentral",
      "metadata": {
        "description": "Azure 리전 (예: koreacentral, eastus2)"
      }
    },
    "foundryName": {
      "type": "string",
      "metadata": {
        "description": "Foundry(AI Services) 계정 이름. 소문자, 숫자, 하이픈만 허용"
      }
    },
    "foundryProjectName": {
      "type": "string",
      "metadata": {
        "description": "Foundry 프로젝트 이름"
      }
    },
    "docName": {
      "type": "string",
      "metadata": {
        "description": "Document Intelligence(AI Services) 계정 이름. prefix: doc-"
      }
    },
    "searchServiceName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60,
      "metadata": {
        "description": "Azure AI Search 서비스 이름. prefix: search-, 소문자, 숫자, 하이픈, 2~60자"
      }
    },
    "bingName": {
      "type": "string",
      "metadata": {
        "description": "Grounding with Bing Search 리소스 이름. prefix: bing-, Foundry 연결용"
      }
    },
    "userPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Resource Group에 Contributor 권한을 부여할 사용자의 Object (Principal) ID. 스크립트로 생성 후 전달"
      }
    },
    "searchSku": {
      "type": "string",
      "defaultValue": "standard",
      "allowedValues": [
        "free",
        "basic",
        "standard",
        "standard2",
        "standard3"
      ],
      "metadata": {
        "description": "AI Search SKU (free | basic | standard | standard2 | standard3)"
      }
    }
  },
  "variables": {
    "contributorRoleId": "b24988ac-6180-42a0-ab88-20f7382dd24c",
    "azureAiUserRoleId": "53ca6127-db72-4b80-b1b0-d745d6d5456d"
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-06-01",
      "name": "[parameters('foundryName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "sku": {
        "name": "S0"
      },
      "kind": "AIServices",
      "properties": {
        "allowProjectManagement": true,
        "customSubDomainName": "[parameters('foundryName')]",
        "disableLocalAuth": false
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "2025-06-01",
      "name": "[format('{0}/{1}', parameters('foundryName'), parameters('foundryProjectName'))]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {},
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-06-01",
      "name": "[parameters('docName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "sku": {
        "name": "S0"
      },
      "kind": "FormRecognizer",
      "properties": {
        "customSubDomainName": "[parameters('docName')]",
        "disableLocalAuth": false
      }
    },
    {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2020-08-01",
      "name": "[parameters('searchServiceName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('searchSku')]"
      },
      "properties": {
        "replicaCount": 1,
        "partitionCount": "[if(equals(parameters('searchSku'), 'free'), 1, 1)]",
        "hostingMode": "default"
      }
    },
    {
      "type": "Microsoft.Bing/accounts",
      "apiVersion": "2020-06-10",
      "name": "[parameters('bingName')]",
      "location": "global",
      "sku": {
        "name": "G1"
      },
      "kind": "Bing.Grounding",
      "properties": {
        "statisticsEnabled": false
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, parameters('userPrincipalId'), variables('contributorRoleId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('contributorRoleId'))]",
        "principalId": "[parameters('userPrincipalId')]",
        "principalType": "User"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, parameters('userPrincipalId'), variables('azureAiUserRoleId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('azureAiUserRoleId'))]",
        "principalId": "[parameters('userPrincipalId')]",
        "principalType": "User"
      }
    }
  ],
  "outputs": {
    "foundryEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName')), '2025-06-01').endpoint]"
    },
    "foundryId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]"
    },
    "foundryProjectId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/projects', parameters('foundryName'), parameters('foundryProjectName'))]"
    },
    "documentIntelligenceEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('docName')), '2025-06-01').endpoint]"
    },
    "docIntelligenceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('docName'))]"
    },
    "searchEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.search.windows.net', parameters('searchServiceName'))]"
    },
    "searchServiceName": {
      "type": "string",
      "value": "[parameters('searchServiceName')]"
    },
    "bingGroundingId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Bing/accounts', parameters('bingName'))]"
    },
    "bingGroundingName": {
      "type": "string",
      "value": "[parameters('bingName')]"
    },
    "resourceGroupName": {
      "type": "string",
      "value": "[parameters('resourceGroupName')]"
    },
    "location": {
      "type": "string",
      "value": "[parameters('location')]"
    }
  }
}